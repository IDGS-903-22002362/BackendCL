rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdminStaff() {
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        request.auth.token.rol in ['ADMIN', 'EMPLEADO', 'SUPER_ADMIN']
      );
    }

    // Notificaciones sanitizadas escritas solo por backend (Admin SDK).
    match /adminNotificaciones/{notificationId} {
      allow read: if isAdminStaff();
      allow write: if false;
    }

    // Estado de lectura por usuario; escritura solo vía REST/backend.
    match /adminNotificationReads/{userId} {
      allow get: if isAdminStaff() && request.auth.uid == userId;
      allow list: if false;
      allow write: if false;
    }

    // Private AI data is managed exclusively by Cloud Functions through the
    // Admin SDK. Recursive wildcards keep both root documents and any future
    // subcollections blocked from every client context.
    match /ai_sessions/{document=**} {
      allow read, write: if false;
    }
    match /ai_messages/{document=**} {
      allow read, write: if false;
    }
    match /ai_tool_calls/{document=**} {
      allow read, write: if false;
    }
    match /ai_audit_logs/{document=**} {
      allow read, write: if false;
    }
    match /tryon_jobs/{document=**} {
      allow read, write: if false;
    }
    match /tryon_assets/{document=**} {
      allow read, write: if false;
    }
    match /ai_admin_proposals/{document=**} {
      allow read, write: if false;
    }
    match /ai_admin_operations/{document=**} {
      allow read, write: if false;
    }
    match /ai_metrics/{document=**} {
      allow read, write: if false;
    }
    match /ai_evals/{document=**} {
      allow read, write: if false;
    }
    match /ai_traces/{document=**} {
      allow read, write: if false;
    }

    // Datos deportivos públicos de Liga MX (calendario, clasificación,
    // plantilla, jugadores y detalle de partidos). La app móvil los lee
    // directamente; solo el backend (Admin SDK, cron syncLigaMxData) escribe.
    match /liga_mx_contexto_actual/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /liga_mx_calendarios_actuales/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /liga_mx_clasificaciones_actuales/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /liga_mx_plantillas_actuales/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /liga_mx_jugadores_actuales/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /liga_mx_partidos_actuales/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /liga_mx_detalles_partido_actuales/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Todo lo demás sigue bloqueado: acceso vía Cloud Functions.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
