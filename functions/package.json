{
  "name": "functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "lint": "echo \"Lint disabled\"",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "cross-env NODE_ENV=development IS_LOCAL=true STORAGE_BUCKET=e-comerce-leon.firebasestorage.app PORT=3000 ts-node-dev --respawn --transpile-only src/dev.ts",
    "dev:watch": "cross-env NODE_ENV=development PORT=3000 nodemon --watch src --ext ts --exec \"npm run build && node lib/index.js\"",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "test": "jest --runInBand",
    "migrate:size-inventory": "ts-node-dev --transpile-only src/scripts/migrate-size-inventory.ts",
    "backfill:search-text": "npm run build && node lib/scripts/backfill-product-search-text.js",
    "repair:stuck-paid-orders": "npm run build && node lib/scripts/repair-stuck-paid-order-state.js",
    "audit:stripe-payments": "npm run build && node lib/scripts/audit-stripe-payment-health.js",
    "test:stripe:smoke": "node scripts/stripe-smoke-test.mjs",
    "logs": "firebase functions:log",
    "validate:openapi": "node -e \"require('swagger-parser').validate('src/modules/loyalty/openapi/loyalty-v1.openapi.yaml').then(()=>console.log('OpenAPI OK')).catch(e=>{console.error(e);process.exit(1);})\"",
    "test:critical:loyalty": "jest --runInBand --testPathPatterns=\"loyalty|legacy-adapter|welcome-bonus|users.points|proxy-path|conversion-rules|payment-loyalty\"",
    "migrate:ledger": "npm run build && node lib/modules/loyalty/scripts/migrate-ledger.js",
    "reconcile:ledger": "npm run build && node lib/modules/loyalty/scripts/reconcile-ledger.js",
    "seed:loyalty-flags": "npm run build && node lib/modules/loyalty/scripts/seed-loyalty-flags.js",
    "activate:loyalty-flags": "npm run build && node lib/modules/loyalty/scripts/activate-loyalty-flags.js",
    "deploy:loyalty-indexes": "firebase deploy --only firestore:indexes --config firebase.app-oficial.json --project app-oficial-leon",
    "loyalty:partner:create": "npm run build && node lib/modules/loyalty/partner/scripts/partner-create.js",
    "loyalty:partner:disable": "npm run build && node lib/modules/loyalty/partner/scripts/partner-disable.js",
    "loyalty:client:create": "npm run build && node lib/modules/loyalty/partner/scripts/client-create.js",
    "loyalty:client:rotate": "npm run build && node lib/modules/loyalty/partner/scripts/client-rotate.js",
    "loyalty:client:revoke": "npm run build && node lib/modules/loyalty/partner/scripts/client-revoke.js",
    "loyalty:test-member:create": "npm run build && node lib/modules/loyalty/partner/scripts/test-member-create.js",
    "loyalty:test-member:reset": "npm run build && node lib/modules/loyalty/partner/scripts/test-member-reset.js",
    "loyalty:test-token:create": "npm run build && node lib/modules/loyalty/partner/scripts/test-token-create.js",
    "generate:loyalty-public-openapi": "node scripts/generate-loyalty-public-openapi.mjs",
    "validate:loyalty-openapi": "node scripts/validate-loyalty-openapi.mjs",
    "e2e:sandbox": "node scripts/e2e-sandbox-partner.mjs",
    "e2e:sandbox:concurrency": "node scripts/e2e-sandbox-concurrency.mjs",
    "e2e:sandbox:battery": "node scripts/e2e-sandbox-live-battery.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@google/generative-ai": "^0.24.1",
    "@sendinblue/client": "^3.3.1",
    "axios": "^1.16.1",
    "busboy": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "file-type": "^21.3.1",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.2.5",
    "form-data": "^4.0.0",
    "google-auth-library": "^10.6.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "openai": "^6.18.0",
    "sharp": "^0.34.5",
    "stripe": "^20.3.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/form-data": "^2.5.0",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.19.11",
    "@types/node-fetch": "^2.6.11",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.1.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.1.4",
    "swagger-parser": "^10.0.3",
    "ts-jest": "^29.4.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.9.0",
    "yaml": "^2.9.0"
  }
}
