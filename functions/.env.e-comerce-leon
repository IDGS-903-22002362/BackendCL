# Variables no secretas para deploy en proyecto e-comerce-leon (CI + firebase deploy).
# Firebase carga este archivo automaticamente: .env.<projectId>
CORS_ALLOWED_ORIGINS=https://ecomerce-next-front--e-comerce-leon.us-central1.hosted.app,https://tiendalaguarida.com,https://www.tiendalaguarida.com,http://localhost:3001
GCP_PROJECT_ID=e-comerce-leon
GCP_REGION=us-central1

# --- Probador virtual (try-on) ---
AI_TRYON_ENABLED=true
AI_TRYON_CONSENT_VERSION=v1
AI_TRYON_USER_RATE_LIMIT_WINDOW_MS=3600000
AI_TRYON_USER_RATE_LIMIT_MAX=10
AI_TRYON_IDEMPOTENCY_WINDOW_MS=300000
