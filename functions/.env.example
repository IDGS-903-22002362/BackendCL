# ============================================================
# Variables de entorno — Club León Backend (Cloud Functions)
# ============================================================
# Copia este archivo como .env y rellena los valores reales.
#   cp .env.example .env
#
# NUNCA subas .env al repositorio (ya está en .gitignore).
# Para desarrollo local con secretos, usa también .env.local (también ignorado):
#   cp .env.example .env.local
# ============================================================

# --- Entorno ---
IS_LOCAL=true
NODE_ENV=development
PORT=3000

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_CURRENCY=mxn
APP_URL=http://localhost:3000

# --- Auth JWT (backend) ---
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
FIREBASE_WEB_API_KEY=
WEB_API_KEY=

# --- Instagram / Meta (opcional) ---
# INSTAGRAM_TOKEN=
# INSTAGRAM_IG_USER_ID=
# IG_BUSINESS_ID=
# META_PAGE_TOKEN=

# --- OpenAI (opcional) ---
# OPENAI_API_KEY=your_openai_api_key_here

# --- AI / Gemini ---
AI_GEMINI_MODE=vertexai
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL_PRIMARY=gemini-2.5-pro
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_SUMMARY=gemini-2.5-flash-lite
AI_GEMINI_TIMEOUT_MS=30000
AI_GEMINI_TEMPERATURE=0.2
AI_MAX_TOOL_STEPS=6
AI_CONTEXT_MAX_MESSAGES=12
AI_SUMMARY_MAX_CHARS=2500

# --- Google Cloud / Vertex AI ---
# GOOGLE_GENAI_USE_VERTEXAI=true
GCP_PROJECT_ID=e-comerce-leon
GCP_REGION=us-central1
VERTEX_TRYON_MODEL=virtual-try-on-001
AI_PREVIEW_MOCKUP_MODEL=imagen-product-recontext-preview-06-30
AI_PREVIEW_MOCKUP_API_VERSION=
AI_PREVIEW_MOCKUP_TIMEOUT_MS=120000
AI_PREVIEW_MOCKUP_FALLBACK_MODEL=gemini-2.5-flash-image
AI_PREVIEW_MOCKUP_FALLBACK_REGION=us-central1
AI_PREVIEW_MOCKUP_FALLBACK_API_VERSION=v1
VERTEX_TRYON_PUBLISHER=google
AI_TRYON_TIMEOUT_MS=120000
AI_TRYON_POLL_INTERVAL_MS=4000

# --- AI API / Rate limiting ---
AI_ENABLE_SSE=true
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=30

# --- AI Uploads / Storage ---
AI_UPLOAD_MAX_MB=10
AI_UPLOAD_MAX_FILES=1
AI_UPLOAD_MIN_WIDTH=512
AI_UPLOAD_MIN_HEIGHT=512
AI_STORAGE_BUCKET=e-comerce-leon-ai-private
GCS_TRYON_BUCKET=e-comerce-leon-ai-private
AI_STORAGE_UPLOAD_FOLDER=ai/uploads
AI_STORAGE_RESULT_FOLDER=ai/tryon-results
AI_SIGNED_URL_TTL_SEC=900
AI_STORAGE_PUBLIC=false

# --- Storefront links ---
STORE_PUBLIC_BASE_URL=https://TU-DOMINIO-REAL.com
STORE_PRODUCT_PATH_TEMPLATE=/productos/:id

# --- Firebase (solo si no usas serviceAccountKey.json) ---
# SERVICE_ACCOUNT_KEY=<JSON completo del service account>
# SERVICE_ACCOUNT_APP_OFICIAL=<JSON completo del service account>
