# ============================================================
# Variables de entorno — Club León Backend (Cloud Functions)
# ============================================================
# Copia este archivo como .env y rellena los valores reales.
#   cp .env.example .env
#
# NUNCA subas .env al repositorio (ya está en .gitignore).
# Para desarrollo local con secretos, usa también .env.local (también ignorado):
#   cp .env.example .env.local
# ============================================================

# --- Entorno ---
IS_LOCAL=true
NODE_ENV=development
PORT=3000

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_CURRENCY=mxn
APP_URL=http://localhost:3000

# --- Auth JWT (backend) ---
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# --- Instagram / Meta (opcional) ---
# INSTAGRAM_TOKEN=
# INSTAGRAM_IG_USER_ID=
# IG_BUSINESS_ID=
# META_PAGE_TOKEN=

# --- OpenAI (opcional) ---
# OPENAI_API_KEY=your_openai_api_key_here

# --- Firebase (solo si no usas serviceAccountKey.json) ---
# SERVICE_ACCOUNT_KEY=<JSON completo del service account>
# SERVICE_ACCOUNT_APP_OFICIAL=<JSON completo del service account>
